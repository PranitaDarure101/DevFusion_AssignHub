rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).role == "admin";
    }

    function isApprovedStudent() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).role == "student"
        && userDoc(request.auth.uid).status == "approved";
    }

    // ── users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      // Self-registration only: a user may create their own doc, and only
      // as a pending student. Admin accounts are seeded out-of-band via
      // the Admin SDK, which bypasses these rules entirely.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role == "student"
        && request.resource.data.status == "pending";

      // Admins may edit anything (approve/reject, role changes, etc).
      // A student may edit only their own doc, and never the fields
      // that control access: role, status, approvedAt, approvedBy.
      allow update: if isAdmin()
        || (
          isSignedIn() && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.approvedBy == resource.data.approvedBy
          && request.resource.data.approvedAt == resource.data.approvedAt
        );

      allow delete: if isAdmin();
    }

    // ── assignments ──────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      // Approved students may only read assignments targeted at them
      // directly or via the ["ALL"] sentinel. Pending/rejected students
      // and unauthenticated users get nothing.
      allow read: if isAdmin()
        || (
          isApprovedStudent()
          && resource.data.assignedStudents.hasAny([request.auth.uid, "ALL"])
        );

      // Only admins author assignments.
      allow create, update, delete: if isAdmin();
    }

    // ── submissions ────────────────────────────────────────────────────
    match /submissions/{submissionId} {
      // A student may read only their own submission; admins read all.
      allow read: if isAdmin()
        || (isApprovedStudent() && resource.data.studentId == request.auth.uid);

      // A student may create only a submission authored as themselves.
      allow create: if isApprovedStudent()
        && request.resource.data.studentId == request.auth.uid;

      // Submissions are immutable once created from the student's side
      // — no student, including the author, may edit or delete one.
      // Admins retain update/delete for corrections.
      allow update, delete: if isAdmin();
    }

    // ── deny everything else by default ───────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
